{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Z Dev Toolbox",
  "version": "1.0.5",
  "identifier": "com.goalonez.zdevtoolbox",
  "build": {
    "beforeDevCommand": "pnpm --filter @z-dev-toolbox/desktop dev",
    "beforeBuildCommand": "pnpm --filter @z-dev-toolbox/desktop build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Z Dev Toolbox",
        "width": 1320,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Goalonez/z-dev-toolbox/releases/latest/download/latest.json"
      ]
    }
  }
}
